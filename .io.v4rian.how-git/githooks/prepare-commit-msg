#!/usr/bin/env bash
# prepare-commit-msg - the smart auto-fix layer for commit messages.
#
# Fires after git has assembled the initial commit message (whatever the
# author typed, the merge template, the revert template, etc.) and before
# the editor opens (or in the case of git commit -m, before the commit
# is recorded). This is the right hook for message rewrites because
# editing here is invisible to the author: when the editor opens, they
# already see the cleaned-up version and can accept or refine.
#
# Pipeline:
#
#   1. Skip on merge, squash, and amend message sources: those have
#      different conventions and the auto-fix layer is calibrated for
#      regular commits.
#   2. Source the shared auto-fix library.
#   3. Stash a derived [TAG] from the staged diff into the environment
#      so auto_fix_message can prepend it if the title has none.
#   4. Run auto_fix_message on the message file. This rewrites in place.
#   5. Run audit_message; if it returns non-zero, surface the WHAT /
#      WHY / DECIDE block and abort the commit. Otherwise let git
#      continue.
#
# The hook is aggressive on auto-fix and sparing on rejection.

set -uo pipefail

msg_file="$1"
source="${2:-}"
sha="${3:-}"

# Skip on message sources where the auto-fix conventions do not apply.
case "$source" in
  merge|squash|commit)
    exit 0
    ;;
esac

# Skip conventional-commit-style messages (chore:, chore(scope):, feat:, fix:,
# refactor:, etc.). Those are typically machine-generated by claim scripts
# (chore(version): bump) or follow a different convention; the v4rian auto-fix
# pipeline is calibrated for [TAG] Title shape and would corrupt the
# conventional form by prepending a [TAG] in front of it.
subj=$(head -n1 "$msg_file" 2>/dev/null || true)
if [[ "$subj" =~ ^[a-z]+(\([^\)]+\))?:[[:space:]] ]]; then
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
LIB="$REPO_ROOT/.io.v4rian.how-git/scripts/lib/auto-fix-commit-message.sh"

if [ ! -f "$LIB" ]; then
  # Library missing: nothing this hook can safely do. Exit clean so
  # users with partial installs are not blocked.
  exit 0
fi

# shellcheck disable=SC1090
. "$LIB"

# Derive a tag from the staged diff shape, then export it so the auto-fix
# python block can pick it up via the environment.
export AUTO_FIX_DERIVED_TAG="$(derive_tag_from_diff)"

auto_fix_message "$msg_file"

# Run the unreconcilable-condition audit. Abort on failure.
if ! audit_message "$msg_file"; then
  exit 1
fi

exit 0
