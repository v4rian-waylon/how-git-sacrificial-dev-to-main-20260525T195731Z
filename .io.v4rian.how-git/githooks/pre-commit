#!/usr/bin/env bash
# pre-commit - staged-file content scrub for em-dashes and banned tokens.
#
# Fires before the commit is recorded, after staging. Scrubs every staged
# text file in place (working tree + index) for the same characters and
# tokens that prepare-commit-msg removes from the commit message, so the
# repo content and the message stay in lockstep on the auto-fix rules.
#
# Pipeline:
#
#   1. Enumerate staged text files. Skip binaries (the staged blob's
#      first 8 KB are scanned for a NUL byte).
#   2. Skip files under .git/, node_modules/, build/, build-*/, vendor
#      dirs, and the auto-fix library itself (which intentionally
#      contains the dash characters as regex data).
#   3. For each surviving file, replace em-dashes (U+2014) and en-dashes
#      (U+2013) with hyphens and re-stage the result. Other transforms
#      that risk semantic damage to code (renaming "plus" to "and",
#      reshaping bullets) are intentionally left to the prepare-commit-msg
#      hook so source code is never silently retyped.
#   4. If any file was rewritten, surface a one-line note per file so
#      the author can see what changed before the editor opens.
#
# The hook never blocks the commit on its own. It augments the diff and
# lets git commit proceed; if the author dislikes the rewrite they can
# git reset HEAD and commit the original.

set -uo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# Files to skip even if staged.
_skip_path() {
  local p="$1"
  case "$p" in
    .git/*|*/node_modules/*|*/build/*|*/build-*/*|*/vendor/*|*/.venv/*) return 0 ;;
    .io.v4rian.how-git/scripts/lib/auto-fix-commit-message.sh) return 0 ;;
    .io.v4rian.how-git/test/test-hooks.sh) return 0 ;;
    .io.v4rian.how-git/test/test-lifecycle.sh) return 0 ;;
  esac
  return 1
}

# Return 0 if the file looks like text (no NUL bytes in the first 8 KB).
_is_text_file() {
  local p="$1"
  [ -f "$p" ] || return 1
  if head -c 8192 "$p" 2>/dev/null | LC_ALL=C grep -q $'\x00'; then
    return 1
  fi
  return 0
}

# Collect staged file paths (relative to repo root). --cached --diff-filter=ACMRT
# excludes deletions so we never try to rewrite something git no longer tracks.
staged_files=$(git diff --cached --name-only --diff-filter=ACMRT 2>/dev/null)

rewritten_count=0
rewritten_paths=()

while IFS= read -r relpath; do
  [ -z "$relpath" ] && continue
  if _skip_path "$relpath"; then
    continue
  fi
  abspath="$REPO_ROOT/$relpath"
  if ! _is_text_file "$abspath"; then
    continue
  fi
  # Scan for em-dash or en-dash. Fast path: skip if neither present.
  if ! LC_ALL=C grep -q -e $'\xe2\x80\x94' -e $'\xe2\x80\x93' "$abspath" 2>/dev/null; then
    continue
  fi
  # Rewrite in place. The python pass is portable across BSD and GNU sed
  # without relying on -i flavor differences.
  python3 - "$abspath" <<'PY'
import sys
p = sys.argv[1]
with open(p, 'r', encoding='utf-8', errors='replace') as f:
    s = f.read()
new = s.replace('—', '-').replace('–', '-')
if new != s:
    with open(p, 'w', encoding='utf-8') as f:
        f.write(new)
PY
  # Re-stage the rewritten file so the commit captures the cleaned content.
  git add -- "$abspath" >/dev/null 2>&1 || true
  rewritten_count=$((rewritten_count + 1))
  rewritten_paths+=("$relpath")
done <<< "$staged_files"

if [ "$rewritten_count" -gt 0 ]; then
  echo ">> pre-commit auto-fix scrubbed em-dashes / en-dashes in $rewritten_count file(s):" >&2
  for p in "${rewritten_paths[@]}"; do
    echo "   $p" >&2
  done
fi

exit 0
